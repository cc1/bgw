---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { fetchResearchArticles } from '../data/research-articles';
import { url } from '../utils/paths';

const researchArticles = await fetchResearchArticles();
const recentResearch = researchArticles.slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-12 md:pt-24 md:pb-16">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <div class="w-48 h-48 md:w-56 md:h-56 rounded-full overflow-hidden flex-shrink-0 bg-stone-200">
        <img
          src={url("/images/profile/beth-profile.jpg")}
          alt="Beth H. Glick"
          class="w-full h-full object-cover"
        />
      </div>
      <div>
        <h1 class="font-serif text-3xl md:text-4xl font-medium text-stone-800 mb-4">
          Beth H. Glick
        </h1>
        <p class="text-lg text-stone-600 leading-relaxed max-w-xl">
          Consciousness researcher &amp; organizational strategist
        </p>
        <p class="text-base text-stone-500 italic leading-relaxed max-w-xl mt-2">
          How we experience the world shapes how we act, relate, and create
        </p>
        <p class="text-base text-stone-500 italic leading-relaxed max-w-xl mt-1">
          From everyday perception to extraordinary experience
        </p>
      </div>
    </div>
  </section>

  <!-- Research -->
  <section class="max-w-5xl mx-auto px-6 py-12 border-t border-stone-200">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-serif text-2xl text-stone-800">Ideas</h2>
      <a href={url("/ideas")} class="text-sm text-stone-500 hover:text-stone-800 transition-colors">
        View all &rarr;
      </a>
    </div>
    <div class="space-y-8">
      {recentResearch.map(article => (
        <ArticleCard
          title={article.title}
          date={article.date}
          excerpt={article.excerpt}
          image={url(article.image)}
          href={article.substackUrl}
          external={true}
        />
      ))}
    </div>
  </section>

</BaseLayout>
