---
import BaseLayout from '../layouts/BaseLayout.astro';

// Reverse chronological. Adjust dates if a formal publication date is
// assigned to any "forthcoming" entry.
const publications = [
  {
    title: "Semantic Structure and Correspondence in Prospective Trance-Channeled Communications Attributed to Extraterrestrial Intelligences",
    journal: "World Futures",
    date: "2026",
    coauthors: "Helané Wahbeh, Beth Glick",
    description: "An analysis of the semantic structure and correspondence of prospective trance-channeled communications attributed to extraterrestrial intelligences.",
    url: "https://www.tandfonline.com/doi/full/10.1080/02604027.2026.2656120",
  },
  {
    title: "Investigating Individual Intuitive Expression: Norms and Patterns in the Noetic Signature Inventory",
    journal: "Journal of Consciousness Studies",
    date: "January 2026",
    coauthors: "Helané Wahbeh, Beth Glick, Michael Kriegsman",
    description: "A large-scale study validating the Noetic Signature Inventory (NSI) and mapping patterns in how individuals experience and report intuitive and noetic phenomena.",
    url: "https://www.ingentaconnect.com/contentone/imp/jcs/2025/00000032/f0020011/art00005",
  },
  {
    title: "Semantic Correspondence Between Trance-Channeled ET Messages and Ufological Records",
    journal: "Journal of Scientific Exploration (forthcoming)",
    date: "2026",
    coauthors: "Helané Wahbeh, Beth Glick, Erik Brinsmead, Sitara Taddeo, Ryan S. Wood",
    description: "A computational analysis comparing trance-channeled ET communications with a 750,000-page ufological archive, identifying striking areas of thematic convergence and divergence across independent sources.",
    url: "https://figshare.com/articles/journal_contribution/Pre-print_Semantic_Correspondence_Between_Trance-Channeled_ET_Messages_and_Ufological_Records/29912276?file=57193190",
  },
  {
    title: "Can Trance Channeling Be Learned? A Case Study of a Scientist's Experience",
    journal: "Journal of Scientific Exploration",
    date: "December 2025",
    coauthors: "Helané Wahbeh, Sitara Taddeo, Beth Glick",
    description: "A case study examining whether a structured hypnotic protocol can reliably induce trance channeling, suggesting that the capacity may be both trainable and linked to out-of-body states.",
    url: "https://journalofscientificexploration.org/index.php/jse/article/view/3573",
  },
  {
    title: "Reports of Non-Physical Beings Assisting in Reiki Sessions",
    journal: "Anthropology of Consciousness",
    date: "August 2025",
    coauthors: "Helané Wahbeh, Beth Glick, Juliette Gallo, Garret Yount",
    description: "A mixed-methods study of Reiki sessions investigating reports of non-physical entities and their perceived influence on healing processes.",
    url: "https://anthrosource.onlinelibrary.wiley.com/doi/10.1111/anoc.70009",
  },
];
---

<BaseLayout title="Research" description="Research and peer-reviewed publications by Beth Glick on consciousness, perception, and anomalous experience.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-12 md:pt-24">
    <h1 class="font-serif text-3xl text-stone-800 mb-6">Research</h1>

    <p class="text-stone-600 leading-relaxed mb-16 max-w-2xl">
      My research investigates the edges of human perception: the anomalous, the mystical, and the ordinarily overlooked. What these experiences reveal about the structure of consciousness itself.
    </p>

    <!-- Current Research -->
    <h2 class="font-serif text-xl text-stone-800 mb-4">Current Research</h2>
    <div class="prose mb-16">
      <p class="font-medium text-stone-700">Doctoral Research</p>
      <p>
        My dissertation develops a new instrument, the Exceptional Experience Integration &amp; Impact Measure (EXIM), for measuring how exceptional experiences integrate into a person's identity, worldview, relationships, and behavior. The same experience can produce a healer or a cult leader. I'm investigating what shapes the difference.
      </p>
    </div>

    <!-- Publications -->
    <h2 class="font-serif text-xl text-stone-800 mb-8">Peer-Reviewed Publications</h2>
    <div class="space-y-8">
      {publications.map(pub => (
        <article class="border-b border-stone-200 pb-8 last:border-0">
          {pub.url ? (
            <h3 class="text-base font-medium mb-1">
              <a
                href={pub.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-stone-800 hover:text-accent transition-colors underline underline-offset-2 decoration-stone-300 hover:decoration-accent"
              >
                {pub.title}
              </a>
            </h3>
          ) : (
            <h3 class="text-base font-medium text-stone-800 mb-1">{pub.title}</h3>
          )}
          <p class="text-sm text-stone-500 mb-1">
            {pub.journal}, {pub.date}
          </p>
          <p class="text-sm text-stone-500 mb-3">{pub.coauthors}</p>
          <p class="text-sm text-stone-400">{pub.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
