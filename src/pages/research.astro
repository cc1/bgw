---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { fetchResearchArticles } from '../data/research-articles';
import { url } from '../utils/paths';

const researchArticles = await fetchResearchArticles();
---

<BaseLayout title="Research" description="Beth Glick's research exploring consciousness, extended human capacities, synchronicities, and mystical experiences.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-12 md:pt-24">
    <h1 class="font-serif text-3xl text-stone-800 mb-6">Research</h1>

    <p class="text-stone-600 leading-relaxed mb-6">
      I am a PhD student, writer, and researcher examining the edges of consciousness, extended human capacities, synchronicities, and mystical experiences that offer us portals to meaning, purpose, and sense-making. I collaborate with organizations that investigate consciousness, non-dual states, and anomalous phenomena.
    </p>

    <!-- Substack CTA -->
    <div class="bg-stone-100 rounded-xl px-6 py-5 mb-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="text-sm font-medium text-stone-700">Into Intuition</p>
        <p class="text-sm text-stone-500 mt-1">Subscribe to my newsletter on consciousness, anomalous phenomena, and holding it all lightly.</p>
      </div>
      <a
        href="https://intointuition.substack.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 bg-stone-800 text-white text-sm rounded-lg hover:bg-stone-700 transition-colors flex-shrink-0"
      >
        Subscribe
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

    <h2 class="font-serif text-xl text-stone-800 mb-6">Ideas</h2>

    <!-- Article list -->
    <div class="space-y-10">
      {researchArticles.map(article => (
        <ArticleCard
          title={article.title}
          date={article.date}
          excerpt={article.excerpt}
          image={url(article.image)}
          href={article.substackUrl}
          external={true}
        />
      ))}
    </div>
  </section>
</BaseLayout>
